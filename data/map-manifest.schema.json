{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "map-manifest.schema.json",
  "type": "object",
  "required": ["list"],
  "additionalProperties": false,
  "properties": {
    "list": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["file"],
        "additionalProperties": false,
        "properties": {
          "file": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
