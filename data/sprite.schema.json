{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sprite.schema.json",
  "type": "object",
  "additionalProperties": {
    "type": "object",
    "required": ["file", "rect"],
    "additionalProperties": false,
    "properties": {
      "file": {
        "type": "string",
        "minLength": 1
      },
      "rect": {
        "type": "array",
        "items": { "type": "integer" },
        "minItems": 4,
        "maxItems": 4
      }
    }
  }
}
