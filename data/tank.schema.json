{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "tank.schema.json",
  "type": "object",
  "required": ["list"],
  "additionalProperties": false,
  "properties": {
    "list": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["selector", "attributes"],
        "additionalProperties": false,
        "properties": {
          "selector": {
            "type": "object",
            "required": ["party", "kind"],
            "additionalProperties": false,
            "properties": {
              "party": {
                "type": "string",
                "enum": ["player", "enemy"]
              },
              "kind": {
                "type": "string",
                "enum": ["basic", "fast", "fast_armored", "fast_bomber", "medium", "heavy"]
              }
            }
          },
          "attributes": {
            "type": "object",
            "required": [
              "bulletMaxCount",
              "bulletRapidFireDelay",
              "bulletSpeed",
              "bulletTankDamage",
              "bulletWallDamage",
              "health",
              "moveSpeed"
            ],
            "additionalProperties": false,
            "properties": {
              "ai": {
                "type": "string",
                "enum": ["classic", "hunter", "ambush", "attack_base"]
              },
              "sprite": {
                "type": "string",
                "enum": ["basic", "fast", "fast_armored", "fast_bomber", "medium", "heavy"]
              },
              "bulletMaxCount": {
                "type": "integer",
                "minimum": 1
              },
              "bulletRapidFireDelay": {
                "type": "number",
                "minimum": 0
              },
              "bulletSpeed": {
                "type": "number",
                "minimum": 1
              },
              "bulletTankDamage": {
                "type": "integer",
                "minimum": 1
              },
              "bulletWallDamage": {
                "type": "integer",
                "enum": [1, 2]
              },
              "health": {
                "type": "integer",
                "minimum": 1
              },
              "moveSpeed": {
                "type": "number",
                "minimum": 0
              }
            }
          }
        }
      }
    }
  }
}
