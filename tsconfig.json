{
  "compilerOptions": {
    "lib": ["ES2020", "DOM"],
    "resolveJsonModule": true,
    "target": "ES2015",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "typeRoots": ["./src/types", "./node_modules/@types"]
  }
}
