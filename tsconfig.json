{
  "compilerOptions": {
    "lib": ["ES2020", "DOM"],
    "resolveJsonModule": true,
    "target": "ES2015",
    "module": "commonjs",
    "moduleResolution": "node10",
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "typeRoots": ["./src/types"]
  }
}
